// =========================
// บันทึกข้อมูลจาก index
// =========================
function submitAttendanceData(

  date,
  grade,
  totalMale,
  totalFemale,
  maleAttend,
  femaleAttend

) {

  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const sheetStats =
    ss.getSheetByName(SHEET_STATS);

  const sheetAttendance =
    ss.getSheetByName(SHEET_ATTENDANCE);


  if (!sheetStats || !sheetAttendance) {

    throw new Error(
      "ไม่พบชีต สถิตินักเรียนทั้งหมด หรือ บันทึกการมาเรียน"
    );

  }


  totalMale =
    Number(totalMale) || 0;

  totalFemale =
    Number(totalFemale) || 0;

  maleAttend =
    Number(maleAttend) || 0;

  femaleAttend =
    Number(femaleAttend) || 0;


  const totalStudent =
    totalMale + totalFemale;

  const totalAttend =
    maleAttend + femaleAttend;


  const dateObj =
    parseDateFromIndex(date);

  const dateKey =
    formatDateKey(dateObj);


  // validate
  if (!date || !grade) {

    throw new Error(
      "กรุณากรอกวันที่และระดับชั้น"
    );

  }


  if (maleAttend > totalMale) {

    throw new Error(
      "จำนวนชายมาเรียนมากกว่าจำนวนชายทั้งหมด"
    );

  }


  if (femaleAttend > totalFemale) {

    throw new Error(
      "จำนวนหญิงมาเรียนมากกว่าจำนวนหญิงทั้งหมด"
    );

  }


  // อัปเดตสถิตินักเรียนทั้งหมด
  upsertStudentStats(

    sheetStats,
    grade,
    totalMale,
    totalFemale,
    totalStudent

  );


  // บันทึกการมาเรียน
  upsertAttendance(
    sheetAttendance,
    dateObj,
    dateKey,
    grade,
    totalMale,
    totalFemale,
    totalStudent,
    maleAttend,
    femaleAttend,
    totalAttend
  );


  return "บันทึกข้อมูลเรียบร้อยแล้ว";

}



// =========================
// อัปเดตชีต สถิตินักเรียนทั้งหมด
// =========================
function upsertStudentStats(

  sheet,
  grade,
  totalMale,
  totalFemale,
  totalStudent

) {

  const lastRow =
    sheet.getLastRow();

  const data =
    sheet.getRange(2, 1, lastRow - 1, 5)
      .getValues();


  for (let i = 0; i < data.length; i++) {

    const className =
      String(data[i][0]).trim();


    // ข้ามแถวรวม
    if (
      !className ||
      className.startsWith("รวม")
    ) {

      continue;

    }


    // เจอห้อง
    if (className === grade) {

      const row = i + 2;

      // B = ชาย
      sheet.getRange(row, 2)
        .setValue(totalMale);

      // C = หญิง
      sheet.getRange(row, 3)
        .setValue(totalFemale);

      // D = รวม
      sheet.getRange(row, 4)
        .setValue(totalStudent);

      return;

    }

  }


  throw new Error(
    `ไม่พบระดับชั้น "${grade}" ในชีตสถิตินักเรียนทั้งหมด`
  );

}



// =========================
// บันทึกชีต การมาเรียน
// =========================
function upsertAttendance(
  sheet,
  dateObj,
  dateKey,
  grade,
  totalMale,
  totalFemale,
  totalStudent,
  maleAttend,
  femaleAttend,
  totalAttend
) {
  const lastRow = sheet.getLastRow();

  if (lastRow > 1) {
    const data = sheet.getRange(2, 1, lastRow - 1, 8).getValues();

    for (let i = data.length - 1; i >= 0; i--) {
      const rowDate = data[i][0];
      const rowGrade = data[i][1];
      const rowDateKey = formatDateKey(parseAnyDate(rowDate));

      if (rowDateKey === dateKey && rowGrade === grade) {
        sheet.deleteRow(i + 2);
      }
    }
  }

  sheet.appendRow([
    dateObj,
    grade,
    totalMale,
    totalFemale,
    totalStudent,
    maleAttend,
    femaleAttend,
    totalAttend
  ]);
}



// =========================
// parse วันที่จาก index
// yyyy-mm-dd
// =========================
function parseDateFromIndex(dateString) {

  const parts =
    String(dateString).split("-");


  return new Date(

    Number(parts[0]),
    Number(parts[1]) - 1,
    Number(parts[2])

  );

}



// =========================
// parse วันที่ทั่วไป
// =========================
function parseAnyDate(value) {

  if (value instanceof Date) {

    return new Date(

      value.getFullYear(),
      value.getMonth(),
      value.getDate()

    );

  }


  if (typeof value === "string") {

    const text =
      value.trim();


    // yyyy-mm-dd
    if (text.includes("-")) {

      const parts =
        text.split("-");


      if (parts[0].length === 4) {

        return new Date(

          Number(parts[0]),
          Number(parts[1]) - 1,
          Number(parts[2])

        );

      }

    }


    // dd/mm/yyyy
    if (text.includes("/")) {

      const parts =
        text.split("/");


      let year =
        Number(parts[2]);


      // พ.ศ.
      if (year > 2400) {

        year -= 543;

      }


      return new Date(

        year,
        Number(parts[1]) - 1,
        Number(parts[0])

      );

    }

  }


  return new Date(value);

}



// =========================
// format วันที่
// =========================
function formatDateKey(dateObj) {

  return Utilities.formatDate(

    dateObj,
    TIMEZONE,
    "yyyy-MM-dd"

  );

}





//-------------------------------------------------- เช็คบันทึกสถิติ



const SHEET_TERM = "ตั้งค่าภาคเรียน";
const SHEET_HOLIDAY = "วันหยุด";


// =========================
// ข้อมูลเริ่มต้นหน้า check
// =========================
function getCheckInitialData() {
  ensureConfigSheets();

  return {
    classes: getClassListForCheck(),
    term: getActiveTermInfo()
  };
  
}


// =========================
// ตรวจสอบห้องที่ยังไม่บันทึก
// =========================
function checkMissingAttendanceAll(options) {
  ensureConfigSheets();

  options = options || {};

  const mode = options.mode || "month";
  const month = options.month || "";
  const selectedGrade = options.grade || "";

  const term = getActiveTerm();

  if (!term) {
    throw new Error("ยังไม่ได้ตั้งค่าภาคเรียนที่มีสถานะ 'ใช้งาน'");
  }

  const today = getTodayOnly();

    let startDate = term.startDate;
    let endDate = term.endDate || today;

  if (mode === "month") {
    if (!month) {
      throw new Error("กรุณาเลือกเดือน");
    }

    const monthRange = getMonthRange(month);

    startDate = maxDate(startDate, monthRange.start);
    endDate = minDate(endDate, monthRange.end);
  }

  if (endDate < startDate) {
    return {
      totalClasses: 0,
      totalSchoolDays: 0,
      totalRecorded: 0,
      totalMissing: 0,
      rows: [],
      message: "ช่วงวันที่ที่เลือกอยู่นอกช่วงเปิดภาคเรียน"
    };
  }

  const holidays = getHolidaySet(startDate, endDate);
  const makeupDays = getMakeupSchoolDaySet(startDate, endDate);
  const schoolDays = getSchoolDays(startDate, endDate, holidays, makeupDays);

  const classes = getClassListForCheck().filter(item => {
    if (!selectedGrade) return true;
    return item.grade === selectedGrade;
  });

  const attendanceMap = getAttendanceMap(startDate, endDate);

  const rows = [];

  let totalRecorded = 0;
  let totalMissing = 0;

  classes.forEach(cls => {
    let recordedCount = 0;
    const missingDates = [];

    schoolDays.forEach(day => {
      const dateKey = formatDateKey(day);
      const key = dateKey + "|" + cls.grade;

      if (attendanceMap[key]) {
        recordedCount++;
      } else {
        missingDates.push({
          dateKey: dateKey,
          display: formatDateThaiShort(day)
        });
      }
    });

    const missingCount = missingDates.length;

    totalRecorded += recordedCount;
    totalMissing += missingCount;

    rows.push({
      grade: cls.grade,
      teacher: cls.teacher,
      requiredDays: schoolDays.length,
      recordedCount: recordedCount,
      missingCount: missingCount,
      missingDates: missingDates
    });
  });

  return {
    mode: mode,
    startDate: formatDateKey(startDate),
    endDate: formatDateKey(endDate),
    totalClasses: classes.length,
    totalSchoolDays: schoolDays.length,
    totalRecorded: totalRecorded,
    totalMissing: totalMissing,
    rows: rows
  };
}


// =========================
// สร้างชีตตั้งค่า ถ้ายังไม่มี
// =========================
function ensureConfigSheets() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  let termSheet = ss.getSheetByName(SHEET_TERM);
  if (!termSheet) {
    termSheet = ss.insertSheet(SHEET_TERM);
    termSheet.getRange(1, 1, 1, 5).setValues([[
      "ปีการศึกษา",
      "ภาคเรียน",
      "วันที่เปิดภาคเรียน",
      "วันที่ปิดภาคเรียน",
      "สถานะ"
    ]]);
  }

  let holidaySheet = ss.getSheetByName(SHEET_HOLIDAY);
  if (!holidaySheet) {
    holidaySheet = ss.insertSheet(SHEET_HOLIDAY);
    holidaySheet.getRange(1, 1, 1, 6).setValues([[
      "วันที่เริ่ม",
      "วันที่สิ้นสุด",
      "ประเภท",
      "รายการ",
      "หมายเหตุ",
      "สถานะ"
    ]]);
  }

  let makeupSheet = ss.getSheetByName(SHEET_MAKEUP_DAY);
  if (!makeupSheet) {
    makeupSheet = ss.insertSheet(SHEET_MAKEUP_DAY);
    makeupSheet.getRange(1, 1, 1, 4).setValues([[
      "วันที่",
      "รายการ",
      "หมายเหตุ",
      "สถานะ"
    ]]);
  }
}


// =========================
// ดึงข้อมูลห้องจาก สถิตินักเรียนทั้งหมด
// =========================
function getClassListForCheck() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(SHEET_STATS);

  if (!sheet) {
    throw new Error("ไม่พบชีตสถิตินักเรียนทั้งหมด");
  }

  const data = sheet.getDataRange().getValues();
  const result = [];

  for (let i = 1; i < data.length; i++) {
    const grade = String(data[i][0]).trim();

    if (!grade || grade.startsWith("รวม")) {
      continue;
    }

    result.push({
      grade: grade,
      teacher: data[i][4] || ""
    });
  }

  return result;
}


// =========================
// ดึงภาคเรียนที่ใช้งาน
// =========================
function getActiveTerm() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(SHEET_TERM);

  if (!sheet || sheet.getLastRow() < 2) {
    return null;
  }

  const data = sheet.getRange(2, 1, sheet.getLastRow() - 1, 5).getValues();

  for (let i = 0; i < data.length; i++) {
    const status = String(data[i][4]).trim();

    if (status === "ใช้งาน") {
      const startDate = parseAnyDate(data[i][2]);
      const endDate = data[i][3] ? parseAnyDate(data[i][3]) : null;

      return {
        year: data[i][0],
        term: data[i][1],
        startDate: startDate,
        endDate: endDate
      };
    }
  }

  return null;
}

function getActiveTermInfo() {
  const term = getActiveTerm();

  if (!term) {
    return null;
  }

  return {
    year: term.year,
    term: term.term,
    startText: formatDateThaiShort(term.startDate),
    endText: term.endDate ? formatDateThaiShort(term.endDate) : "ถึงวันนี้"
  };
}


// =========================
// ดึงวันหยุด
// =========================
function getHolidaySet(startDate, endDate) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(SHEET_HOLIDAY);

  const holidaySet = new Set();

  if (!sheet || sheet.getLastRow() < 2) {
    return holidaySet;
  }

  const data = sheet.getRange(2, 1, sheet.getLastRow() - 1, 6).getValues();

  data.forEach(row => {
    const status = String(row[5]).trim();

    if (status !== "ใช้งาน") {
      return;
    }

    if (!row[0]) {
      return;
    }

    const holidayStart = parseAnyDate(row[0]);
    const holidayEnd = row[1] ? parseAnyDate(row[1]) : holidayStart;

    let current = maxDate(holidayStart, startDate);
    const last = minDate(holidayEnd, endDate);

    while (current <= last) {
      holidaySet.add(formatDateKey(current));
      current = addDays(current, 1);
    }
  });

  return holidaySet;
}


//-----------------ดึงวันเรียนชดเชย
function saveMakeupDaySetting(data) {
  ensureConfigSheets();

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(SHEET_MAKEUP_DAY);

  sheet.appendRow([
    parseAnyDate(data.date),
    data.name,
    data.note || "",
    "ใช้งาน"
  ]);

  return true;
}

function updateMakeupDayStatus(row, status) {
  ensureConfigSheets();

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(SHEET_MAKEUP_DAY);

  sheet.getRange(row, 4).setValue(status);

  return true;
}

function deleteMakeupDay(row) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(SHEET_MAKEUP_DAY);

  sheet.deleteRow(row);

  return true;
}

///-----------

function getMakeupSchoolDaySet(startDate, endDate) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(SHEET_MAKEUP_DAY);

  const makeupSet = new Set();

  if (!sheet || sheet.getLastRow() < 2) {
    return makeupSet;
  }

  const data = sheet.getRange(2, 1, sheet.getLastRow() - 1, 4).getValues();

  data.forEach(row => {
    const dateRaw = row[0];
    const status = String(row[3]).trim();

    if (!dateRaw || status !== "ใช้งาน") return;

    const dateObj = parseAnyDate(dateRaw);

    if (dateObj >= startDate && dateObj <= endDate) {
      makeupSet.add(formatDateKey(dateObj));
    }
  });

  return makeupSet;
}

// =========================
// สร้างรายการวันเรียน
// ข้ามเสาร์-อาทิตย์ และวันหยุด
// =========================
function getSchoolDays(startDate, endDate, holidaySet, makeupSet) {
  const days = [];
  let current = new Date(startDate);

  while (current <= endDate) {
    const day = current.getDay();
    const dateKey = formatDateKey(current);

    const isWeekend = day === 0 || day === 6;
    const isHoliday = holidaySet.has(dateKey);
    const isMakeupDay = makeupSet.has(dateKey);

    if (isMakeupDay) {
      days.push(new Date(current));
    } else if (!isWeekend && !isHoliday) {
      days.push(new Date(current));
    }

    current = addDays(current, 1);
  }

  return days;
}


// =========================
// ดึงข้อมูลที่บันทึกแล้ว
// ชีต บันทึกการมาเรียน
// A วันที่
// B ระดับชั้น
// C ชายมา
// D หญิงมา
// E รวมมา
// =========================
function getAttendanceMap(startDate, endDate) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(SHEET_ATTENDANCE);

  if (!sheet) {
    throw new Error("ไม่พบชีตบันทึกการมาเรียน");
  }

  const map = {};

  if (sheet.getLastRow() < 2) {
    return map;
    }

  const data = sheet.getRange(2, 1, sheet.getLastRow() - 1, 5).getValues();

  data.forEach(row => {
    const rawDate = row[0];
    const grade = row[1];

    if (!rawDate || !grade) {
      return;
    }

    const dateObj = parseAnyDate(rawDate);

    if (dateObj < startDate || dateObj > endDate) {
      return;
    }

    const dateKey = formatDateKey(dateObj);
    const key = dateKey + "|" + grade;

    map[key] = true;
  });

  return map;
}


// =========================
// ช่วงเดือน
// รับค่า yyyy-mm
// =========================
function getMonthRange(monthText) {
  const parts = String(monthText).split("-");
  const year = Number(parts[0]);
  const month = Number(parts[1]);

  const start = new Date(year, month - 1, 1);
  const end = new Date(year, month, 0);

  return {
    start: start,
    end: end
  };
}


// =========================
// helper วันที่
// =========================
function addDays(dateObj, amount) {
  const d = new Date(dateObj);
  d.setDate(d.getDate() + amount);
  return new Date(d.getFullYear(), d.getMonth(), d.getDate());
}

function getTodayOnly() {
  const now = new Date();
  return new Date(now.getFullYear(), now.getMonth(), now.getDate());
}

function maxDate(a, b) {
  return a > b ? a : b;
}

function minDate(a, b) {
  return a < b ? a : b;
}

function formatDateThaiShort(dateObj) {
  const d = dateObj.getDate();
  const m = dateObj.getMonth() + 1;
  const y = dateObj.getFullYear() + 543;

  return `${d}/${m}/${y}`;
}

//---------------------------- แอดมิน

function getAdminSettings() {
  ensureConfigSheets();

  return {
    terms: getTermSettings(),
    holidays: getHolidaySettings(),
    makeupDays: getMakeupDaySettings()
  };
}

function getMakeupDaySettings() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(SHEET_MAKEUP_DAY);
  const result = [];

  if (!sheet || sheet.getLastRow() < 2) {
    return result;
  }

  const data = sheet.getRange(2, 1, sheet.getLastRow() - 1, 4).getValues();

  data.forEach((row, index) => {
    result.push({
      row: index + 2,
      date: row[0] ? formatDateKey(parseAnyDate(row[0])) : "",
      name: row[1] || "",
      note: row[2] || "",
