  sheetDaily.getRange(percentRow, 6)
    .setValue("ร้อยละ")
    .setFontSize(18)
    .setFontFamily("Sarabun")
    .setFontWeight("bold")
    .setHorizontalAlignment("center")
    .setBorder(false, false, false, true, false, false);

  sheetDaily.getRange(percentRow, 7)
    .setValue(percent)
    .setFontSize(18)
    .setFontFamily("Sarabun")
    .setFontWeight("bold")
    .setHorizontalAlignment("center")
    .setBorder(false, false, false, false, false, false);

  sheetDaily.setColumnWidth(1, 150);
  for (let c = 2; c <= 10; c++) {
