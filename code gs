function getAttendanceHistoryForCheck(options) {
  const grade = options.grade;
  const mode = options.mode;
  const month = options.month;

  if (!grade) {
    return [];
  }

  const ss = SpreadsheetApp.getActive();
  const sh = ss.getSheetByName("บันทึกการมาเรียน");

  if (!sh) {
    return [];
  }

  const values = sh.getDataRange().getValues();
  const headers = values.shift();

  const colTimestamp = headers.indexOf("ประทับเวลา");
  const colDate = headers.indexOf("วันที่");
  const colGrade = headers.indexOf("ระดับชั้น");

  const colMaleTotal = headers.indexOf("ชาย (ทั้งหมด)");
  const colFemaleTotal = headers.indexOf("หญิง (ทั้งหมด)");

  const colMaleCome = findHeaderIndex(headers, [
    "ชายมา",
    "ชาย (มาเรียน)",
    "ชายมาเรียน"
  ]);

  const colFemaleCome = findHeaderIndex(headers, [
    "หญิงมา",
    "หญิง (มาเรียน)",
    "หญิงมาเรียน"
  ]);

  const colTotalCome = findHeaderIndex(headers, [
    "รวมมา",
    "รวมมาเรียน"
  ]);

  const range = getCheckDateRange_(mode, month);

  return values
    .filter(row => {
      const rowGrade = String(row[colGrade] || "").trim();
      const rowDate = normalizeDate_(row[colDate]);

      return rowGrade === grade &&
             rowDate >= range.start &&
             rowDate <= range.end;
    })
    .sort((a, b) => normalizeDate_(a[colDate]) > normalizeDate_(b[colDate]) ? 1 : -1)
    .map(row => {
      const maleTotal = colMaleTotal >= 0 ? Number(row[colMaleTotal]) || 0 : "";
      const femaleTotal = colFemaleTotal >= 0 ? Number(row[colFemaleTotal]) || 0 : "";

      const maleCome = colMaleCome >= 0 ? Number(row[colMaleCome]) || 0 : 0;
      const femaleCome = colFemaleCome >= 0 ? Number(row[colFemaleCome]) || 0 : 0;
      const totalCome = colTotalCome >= 0 ? Number(row[colTotalCome]) || 0 : maleCome + femaleCome;

      return {
        dateText: formatDateThai_(row[colDate]),
        grade: row[colGrade],
        maleTotal: maleTotal,
        femaleTotal: femaleTotal,
        maleCome: maleCome,
        femaleCome: femaleCome,
        totalCome: totalCome
      };
    });
}

function findHeaderIndex(headers, names) {
  for (let i = 0; i < names.length; i++) {
    const index = headers.indexOf(names[i]);
    if (index !== -1) return index;
  }
  return -1;
}

function normalizeDate_(value) {
  if (value instanceof Date) {
    return Utilities.formatDate(value, Session.getScriptTimeZone(), "yyyy-MM-dd");
  }

  return String(value).slice(0, 10);
}

function formatDateThai_(value) {
  if (!value) return "";

  const date = value instanceof Date ? value : new Date(value);

  if (isNaN(date.getTime())) {
    return String(value);
  }

  return Utilities.formatDate(date, Session.getScriptTimeZone(), "dd/MM/yyyy");
}

function getCheckDateRange_(mode, month) {
  if (mode === "month") {
    const start = month + "-01";
    const parts = month.split("-");
    const year = Number(parts[0]);
    const m = Number(parts[1]);

    const lastDate = new Date(year, m, 0);
    const end = Utilities.formatDate(lastDate, Session.getScriptTimeZone(), "yyyy-MM-dd");

    return {
      start: start,
      end: end
    };
  }

  const term = getActiveTermInfo();

  return {
    start: term.start,
    end: term.end
  };
}
