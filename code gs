const SHEET_STATS = "สถิตินักเรียนทั้งหมด";
const SHEET_ATTENDANCE = "บันทึกการมาเรียน";
const SHEET_MAKEUP_DAY = "วันเรียนชดเชย";
const TIMEZONE = "Asia/Bangkok";

//------------------ API
function doPost(e) {
  try {
    const data = JSON.parse(e.postData.contents);
    const action = data.action;

    if (action === "saveAttendance") {
      const result = submitAttendanceData(
        data.date,
        data.grade,
        data.totalMale,
        data.totalFemale,
        data.maleAttend,
        data.femaleAttend
      );

      return jsonResponse({
        success: true,
        message: result
      });
    }

    if (action === "getCheckInitialData") {
      return jsonResponse({
        success: true,
        data: getCheckInitialData()
      });
    }

    if (action === "checkMissingAttendanceAll") {
      return jsonResponse({
        success: true,
        data: checkMissingAttendanceAll(data.options)
      });
    }

    if (action === "generateAttendanceReportByDate") {

      return jsonResponse({
        success: true,
        data: generateAttendanceReportByDate(data.date)
      });

    }

    if (action === "getAdminSettings") {
      return jsonResponse({
        success: true,
        data: getAdminSettings()
      });
    }

    if (action === "saveTermSetting") {
      return jsonResponse({
        success: true,
        data: saveTermSetting(data.data)
      });
    }

    if (action === "activateTerm") {
      return jsonResponse({
        success: true,
        data: activateTerm(data.row)
      });
    }

    if (action === "saveHolidaySetting") {
      return jsonResponse({
        success: true,
        data: saveHolidaySetting(data.data)
      });
    }

    if (action === "updateHolidayStatus") {
      return jsonResponse({
        success: true,
        data: updateHolidayStatus(data.row, data.status)
      });
    }

    if (action === "deleteSettingRow") {
      return jsonResponse({
        success: true,
        data: deleteSettingRow(data.type, data.row)
      });
    }


    if (action === "saveMakeupDaySetting") {
      return jsonResponse({
        success: true,
        data: saveMakeupDaySetting(data.data)
      });
    }

    if (action === "updateMakeupDayStatus") {
      return jsonResponse({
        success: true,
        data: updateMakeupDayStatus(data.row, data.status)
      });
    }

    if (action === "deleteMakeupDay") {
      return jsonResponse({
        success: true,
        data: deleteMakeupDay(data.row)
      });
    }

    if (action === "getAttendanceHistoryForCheck") {
      return jsonResponse({
        success: true,
        data: getAttendanceHistoryForCheck(data.options)
      });
    }

    return jsonResponse({
      success: false,
      message: "ไม่พบ action ที่ต้องการ: " + action
    });

  } catch (err) {
    return jsonResponse({
      success: false,
      message: err.message
    });
  }
}


function jsonResponse(obj) {
  return ContentService
    .createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}


