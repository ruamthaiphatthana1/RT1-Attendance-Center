function buildDailyAttendanceReport(dateObj) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const sheetStats = ss.getSheetByName("สถิตินักเรียนทั้งหมด");
  const sheetAttendance = ss.getSheetByName("บันทึกการมาเรียน");

  let sheetDaily = ss.getSheetByName("สรุปการมาเรียนรายวัน");
  if (!sheetDaily) {
    sheetDaily = ss.insertSheet("สรุปการมาเรียนรายวัน");
  }

  const dateKey = rptFormatDateKey(dateObj);
  const classes = rptGetClassList(sheetStats);
  const attendanceMap = rptGetAttendanceMap(sheetAttendance, dateKey);

  const result = [];

  let grandMaleTotal = 0;
  let grandFemaleTotal = 0;
  let grandTotal = 0;
  let grandMaleAttend = 0;
  let grandFemaleAttend = 0;
  let grandAttend = 0;
  let grandMaleAbsent = 0;
  let grandFemaleAbsent = 0;
  let grandAbsent = 0;

  const groups = {
    "อนุบาล": [],
    "ประถม": [],
    "มัธยม": []
  };

  const groupSum = {
    "อนุบาล": [0,0,0,0,0,0,0,0,0,""],
    "ประถม": [0,0,0,0,0,0,0,0,0,""],
    "มัธยม": [0,0,0,0,0,0,0,0,0,""]
  };

  classes.forEach(cls => {
    const attend = attendanceMap[cls.grade] || {
      totalMale: cls.male,
      totalFemale: cls.female,
      totalStudent: cls.total,
      male: 0,
      female: 0,
      total: 0
    };

    const maleTotal =
      attend.totalMale;

    const femaleTotal =
      attend.totalFemale;

    const totalStudent =
      attend.totalStudent;

    const maleAbsent =
      Math.max(0, maleTotal - attend.male);

    const femaleAbsent =
      Math.max(0, femaleTotal - attend.female);

    const totalAbsent =
      Math.max(0, totalStudent - attend.total);

    const row = [
      cls.grade,
      maleTotal,
      femaleTotal,
      totalStudent,
      attend.male,
      attend.female,
      attend.total,
      maleAbsent,
      femaleAbsent,
      totalAbsent,
      cls.teacher
    ];

    const group = cls.grade.includes("อนุบาล")
      ? "อนุบาล"
      : cls.grade.includes("ประถม")
        ? "ประถม"
        : "มัธยม";

    groups[group].push(row);

    for (let i = 0; i < 9; i++) {
      groupSum[group][i] += row[i + 1];
    }

    grandMaleTotal += maleTotal;
    grandFemaleTotal += femaleTotal;
    grandTotal += totalStudent;
    grandMaleAttend += attend.male;
    grandFemaleAttend += attend.female;
    grandAttend += attend.total;
    grandMaleAbsent += maleAbsent;
    grandFemaleAbsent += femaleAbsent;
    grandAbsent += totalAbsent;
  });

  Object.keys(groups).forEach(group => {
    result.push(...groups[group]);
    result.push(["รวมระดับ" + group, ...groupSum[group]]);
  });

  result.push([
    "รวมทั้งหมด",
    grandMaleTotal,
    grandFemaleTotal,
    grandTotal,
    grandMaleAttend,
    grandFemaleAttend,
    grandAttend,
    grandMaleAbsent,
    grandFemaleAbsent,
    grandAbsent,
    ""
  ]);

  const percent = grandTotal > 0
    ? ((grandAttend / grandTotal) * 100).toFixed(2)
    : "0.00";

  const thaiDate = rptThaiDateFull(dateObj);

  sheetDaily.clear();

  sheetDaily.getRange(1, 1, 1, 11).merge();
  sheetDaily.getRange(1, 1)
    .setFormula('=IMAGE("https://drive.google.com/uc?export=view&id=1R41aBcyj7bLtuy7DuzB0gdTfNYoNkhe-", 4, 132, 132)')
    .setHorizontalAlignment("center")
    .setVerticalAlignment("middle");

  sheetDaily.setRowHeight(1, 132);

  sheetDaily.getRange(2, 1, 1, 11).merge()
    .setValue("สถิติการมาเรียนของนักเรียนโรงเรียนรวมไทยพัฒนา 1 ภาคเรียนที่ 1 ปีการศึกษา 2568")
    .setFontWeight("bold")
    .setFontSize(24)
    .setFontFamily("Sarabun")
    .setHorizontalAlignment("center");

  sheetDaily.getRange(3, 1, 1, 11).merge()
    .setValue(thaiDate)
    .setFontWeight("bold")
    .setFontSize(24)
    .setFontFamily("Sarabun")
    .setHorizontalAlignment("center");


  sheetDaily.getRange(5, 1, 2, 1).merge().setValue("ชั้นเรียน");
  sheetDaily.getRange(5, 2, 1, 3).merge().setValue("จำนวนนักเรียนทั้งหมด");
  sheetDaily.getRange(5, 5, 1, 3).merge().setValue("มาเรียน");
  sheetDaily.getRange(5, 8, 1, 3).merge().setValue("ไม่มาเรียน");
  sheetDaily.getRange(5, 11, 2, 1).merge().setValue("ครูประจำชั้น");

  sheetDaily.getRange(6, 2, 1, 9).setValues([[
    "ชาย", "หญิง", "รวม",
    "ชาย", "หญิง", "รวม",
    "ชาย", "หญิง", "รวม"
  ]]);

  const headerRange = sheetDaily.getRange(5, 1, 2, 11);
  headerRange
    .setFontSize(18)
    .setFontFamily("Sarabun")
    .setFontWeight("bold")
    .setHorizontalAlignment("center")
    .setVerticalAlignment("middle")
    .setBorder(true, true, true, true, true, true);

  const dataRange = sheetDaily.getRange(7, 1, result.length, 11);
  dataRange
    .setValues(result)
    .setFontSize(18)
    .setFontFamily("Sarabun")
    .setHorizontalAlignment("center")
    .setVerticalAlignment("middle")
    .setBorder(true, true, true, true, true, true);

  sheetDaily.getRange(7, 11, result.length, 1).setHorizontalAlignment("left");

  for (let i = 0; i < result.length; i++) {
    const label = String(result[i][0]);
    if (label.startsWith("รวมระดับ") || label === "รวมทั้งหมด") {
      sheetDaily.getRange(i + 7, 1, 1, 11)
        .setFontWeight("bold")
        .setBackground("#fff59d");
