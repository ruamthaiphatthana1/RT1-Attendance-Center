function rptGetClassList(sheet) {
  const data = sheet.getDataRange().getValues();
  const result = [];

  for (let i = 1; i < data.length; i++) {
    const grade = String(data[i][0]).trim();

    if (!grade || grade.startsWith("รวม")) continue;

    result.push({
      grade: grade,
      male: Number(data[i][1]) || 0,
      female: Number(data[i][2]) || 0,
      total: Number(data[i][3]) || 0,
      teacher: data[i][4] || ""
    });
  }

  return result;
}

function rptGetAttendanceMap(sheet, dateKey) {
  const map = {};

  if (sheet.getLastRow() < 2) return map;

  const data = sheet.getRange(2, 1, sheet.getLastRow() - 1, 8).getValues();

  data.forEach(row => {
    const rowDate = row[0];
    const grade = row[1];

    if (!rowDate || !grade) return;

    const rowDateKey = rptFormatDateKey(rptParseAnyDate(rowDate));

    if (rowDateKey === dateKey) {
      map[grade] = {
        totalMale: Number(row[2]) || 0,
        totalFemale: Number(row[3]) || 0,
        totalStudent: Number(row[4]) || 0,
        male: Number(row[5]) || 0,
        female: Number(row[6]) || 0,
        total: Number(row[7]) || 0
      };
    }
  });

  return map;
  }

function rptGetDateList(startDate, endDate) {
  const result = [];
  let current = new Date(startDate);

  while (current <= endDate) {
    result.push(new Date(current));
    current.setDate(current.getDate() + 1);
  }

  return result;
}

function rptParseDate(text) {
  const parts = String(text).split("-");
  return new Date(Number(parts[0]), Number(parts[1]) - 1, Number(parts[2]));
}

function rptParseAnyDate(value) {
  if (value instanceof Date) {
    return new Date(value.getFullYear(), value.getMonth(), value.getDate());
  }

  if (typeof value === "string") {
    const text = value.trim();

    if (text.includes("-")) {
      const parts = text.split("-");
      if (parts[0].length === 4) {
        return new Date(Number(parts[0]), Number(parts[1]) - 1, Number(parts[2]));
      }
      return new Date(Number(parts[2]), Number(parts[1]) - 1, Number(parts[0]));
    }

    if (text.includes("/")) {
      const parts = text.split("/");
      let year = Number(parts[2]);
      if (year > 2400) year -= 543;
      return new Date(year, Number(parts[1]) - 1, Number(parts[0]));
    }
  }

  return new Date(value);
}

function rptFormatDateKey(dateObj) {
  return Utilities.formatDate(dateObj, "Asia/Bangkok", "yyyy-MM-dd");
}

